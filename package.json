					"vite": "npm:rolldown-vite@7.3.1"
				}
			},
			"@storybook/addon-vitest": {
				"peerDependencies": {
					"vite": "npm:rolldown-vite@7.3.1"
				}
			},
			"@vitest/mocker": {
				"peerDependencies": {
					"vite": "npm:rolldown-vite@7.3.1"
				}
			},
			"@storybook/csf-plugin": {
				"peerDependencies": {
					"vite": "npm:rolldown-vite@7.3.1"
